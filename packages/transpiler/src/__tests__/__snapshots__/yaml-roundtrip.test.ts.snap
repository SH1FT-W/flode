exports[`YAML round-trip (fixtures) > round-trips 07-adaptive-lighting-complex.yaml to identical YAML 1`] = `
"alias: Adaptive Lighting Quando Accendo Luci
description: ""
triggers:
  - trigger: device
    domain: knx
    device_id: ee504a40b987814032d9ec9c29b1a43f
    type: telegram
    group_value_write: true
    incoming: true
    destination:
      - 2/4/7
      - 2/4/3
      - 2/4/4
      - 2/4/5
      - 2/4/6
      - 0/0/191
      - 0/0/142
      - 0/0/248
      - 0/0/1
actions:
  - variables:
      current_node: condition_test_1_143
      flow_context: {}
  - alias: State Machine Loop
    repeat:
      until: "{{ current_node == \\"END\\" }}"
      sequence:
        - choose:
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"condition_test_1_143\\" }}"
              sequence:
                - variables:
                    current_node: "{% if trigger.payload == 1 %}condition_test_2_144{% else %}END{% endif %}"
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"condition_test_2_144\\" }}"
              sequence:
                - variables:
                    current_node: "{% if target_light is not none %}wait_test_3_145{% else %}END{% endif %}"
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"wait_test_3_145\\" }}"
              sequence:
                - wait_template: "{{ is_state(target_light, 'on') }}"
                  timeout: "00:00:03"
                - variables:
                    current_node: condition_test_4_146
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"condition_test_4_146\\" }}"
              sequence:
                - variables:
                    current_node: "{% if is_state(target_light, 'on') %}action_test_5_147{% else %}END{% endif %}"
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"action_test_5_147\\" }}"
              sequence:
                - action: light.turn_on
                  target:
                    entity_id: "{{ target_light }}"
                  data:
                    brightness_pct: 100
                    transition: 0
                - variables:
                    current_node: delay_test_6_148
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"delay_test_6_148\\" }}"
              sequence:
                - delay:
                    milliseconds: 500
                - variables:
                    current_node: set_variables_test_7_149
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"set_variables_test_7_149\\" }}"
              sequence:
                - variables:
                    color_before: "{% set a = state_attr(target_light, 'hs_color') %} {% set b = state_attr(target_light, 'xy_color') %} {% set c = state_attr(target_light, 'color_temp_kelvin') %} {% set d = state_attr(target_light, 'color_temp') %} {{ [a, b, c, d] }}"
                - variables:
                    current_node: action_test_8_150
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"action_test_8_150\\" }}"
              sequence:
                - action: adaptive_lighting.apply
                  data:
                    entity_id: switch.adaptive_lighting_adapt_color_dali
                    lights:
                      - "{{ target_light }}"
                    turn_on_lights: false
                    adapt_brightness: false
                    adapt_color: true
                    transition: 0
                - variables:
                    current_node: delay_test_9_151
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"delay_test_9_151\\" }}"
              sequence:
                - delay:
                    milliseconds: 350
                - variables:
                    current_node: set_variables_test_10_152
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"set_variables_test_10_152\\" }}"
              sequence:
                - variables:
                    color_after_1: "{% set a = state_attr(target_light, 'hs_color') %} {% set b = state_attr(target_light, 'xy_color') %} {% set c = state_attr(target_light, 'color_temp_kelvin') %} {% set d = state_attr(target_light, 'color_temp') %} {{ [a, b, c, d] }}"
                - variables:
                    current_node: condition_test_11_153
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"condition_test_11_153\\" }}"
              sequence:
                - variables:
                    current_node: "{% if is_state(target_light, 'on') and (color_after_1 == color_before) %}action_test_12_154{% else %}set_variables_test_14_156{% endif %}"
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"action_test_12_154\\" }}"
              sequence:
                - action: adaptive_lighting.apply
                  data:
                    entity_id: switch.adaptive_lighting_adapt_color_dali
                    lights:
                      - "{{ target_light }}"
                    turn_on_lights: false
                    adapt_brightness: false
                    adapt_color: true
                    transition: 0
                - variables:
                    current_node: delay_test_13_155
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"delay_test_13_155\\" }}"
              sequence:
                - delay:
                    milliseconds: 350
                - variables:
                    current_node: set_variables_test_14_156
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"set_variables_test_14_156\\" }}"
              sequence:
                - variables:
                    color_after_2: "{% set a = state_attr(target_light, 'hs_color') %} {% set b = state_attr(target_light, 'xy_color') %} {% set c = state_attr(target_light, 'color_temp_kelvin') %} {% set d = state_attr(target_light, 'color_temp') %} {{ [a, b, c, d] }}"
                - variables:
                    current_node: condition_test_15_157
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"condition_test_15_157\\" }}"
              sequence:
                - variables:
                    current_node: "{% if is_state(target_light, 'on') and (color_after_2 == color_before) %}action_test_16_158{% else %}END{% endif %}"
            - conditions:
                - condition: template
                  value_template: "{{ current_node == \\"action_test_16_158\\" }}"
              sequence:
                - action: adaptive_lighting.apply
                  data:
                    entity_id: switch.adaptive_lighting_adapt_color_dali
                    lights:
                      - "{{ target_light }}"
                    turn_on_lights: false
                    adapt_brightness: false
                    adapt_color: true
                    transition: 0
                - variables:
                    current_node: END
          default:
            - service: system_log.write
              data:
                message: "FLODE: Unknown state \\"{{ current_node }}\\", ending flow"
                level: warning
            - variables:
                current_node: END
mode: single
variables:
  ga_to_light:
    2/4/7: light.zona
    2/4/3: light.camera_da_letto
    2/4/4: light.bagno_padronale
    2/4/5: light.cucina
    2/4/6: light.soggiorno
    0/0/191: light.soffitto_studio
    0/0/142: light.soffitto_bagno_di_servizio
    0/0/248: light.lampadario_soggiorno
    0/0/1: light.faretti_disimpegno
  ga: "{{ trigger.destination }}"
  target_light: "{{ ga_to_light.get(ga) }}"
  _flode_metadata:
    version: 1
    nodes:
      trigger_test_0_142:
        x: 40
        "y": 54
      condition_test_1_143:
        x: 360
        "y": 44
      condition_test_2_144:
        x: 700
        "y": 44
      wait_test_3_145:
        x: 1040
        "y": 59
      condition_test_4_146:
        x: 1340
        "y": 44
      action_test_5_147:
        x: 1680
        "y": 54
      delay_test_6_148:
        x: 2000
        "y": 59
      set_variables_test_7_149:
        x: 2300
        "y": 54
      action_test_8_150:
        x: 2620
        "y": 54
      delay_test_9_151:
        x: 2940
        "y": 59
      set_variables_test_10_152:
        x: 3240
        "y": 54
      condition_test_11_153:
        x: 3560
        "y": 44
      action_test_12_154:
        x: 3900
        "y": 71
      delay_test_13_155:
        x: 4220
        "y": 76
      set_variables_test_14_156:
        x: 4520
