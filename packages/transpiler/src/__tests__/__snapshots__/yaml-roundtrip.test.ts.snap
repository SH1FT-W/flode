exports[`YAML round-trip (fixtures) > round-trips 09-templates.yaml to identical YAML 1`] = `
"alias: "DHW: Smart Arrival (Maria)"
description: "Arrival: Heats if cold (after 5h away). Departure: Turns OFF (only if warm)."
triggers:
  - trigger: zone
    entity_id: person.maria
    event: enter
    zone: zone.city_limits
    id: arriving
  - trigger: zone
    entity_id: person.maria
    event: leave
    zone: zone.city_limits
    id: leaving
  - trigger: numeric_state
    entity_id: water_heater.altherma
    above: 33
    attribute: current_temperature
    id: temp_limit_reached
actions:
  - choose:
      - conditions:
          - condition: trigger
            id: arriving
          - condition: template
            value_template: |
              {{ (as_timestamp(now()) - as_timestamp(trigger.from_state.last_changed)) > 3600 }}
        sequence:
          - if:
              - condition: numeric_state
                entity_id: water_heater.altherma
                above: 39
                attribute: current_temperature
            then:
              - action: notify.mobile_app_iphone_maria
                data:
                  title: 🚿 Hot Water Ready
                  message: Welcome back! There is plenty of hot water waiting for you.
            else:
              - action: water_heater.turn_on
                target:
                  entity_id: water_heater.altherma
              - action: notify.mobile_app_iphone_maria
                data:
                  title: 🚿 Heating Water
                  message: Welcome back! Turning on the water heater now.
      - conditions:
          - condition: or
            conditions:
              - condition: trigger
                id: leaving
              - condition: trigger
                id: temp_limit_reached
          - condition: numeric_state
            entity_id: water_heater.altherma
            above: 33
            attribute: current_temperature
          - condition: not
            conditions:
              - condition: zone
                entity_id: person.maria
                zone: zone.city_limits
        sequence:
          - action: water_heater.turn_off
            target:
              entity_id: water_heater.altherma
mode: single
variables:
  _flode_metadata:
    version: 1
    nodes:
      trigger_test_0_129:
        x: 40
        "y": 300
      trigger_test_1_130:
        x: 40
        "y": 440
      trigger_test_2_131:
        x: 40
        "y": 160
