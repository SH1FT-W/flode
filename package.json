{
  "name": "flode",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:ha": "npm run build && echo '✓ Built and copied to custom_components/flode/www/'",
    "test": "vitest",
    "test:cli": "yarn workspace @flode/transpiler cli",
    "lint": "turbo run lint",
    "lint:biome": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "yarn biome format --write .",
    "format:check": "yarn biome format .",
    "format:biome": "biome format --write .",
    "check": "biome check . ; yarn typecheck ; yarn lint:biome ; yarn format:check",
    "check:fix": "biome check --write --unsafe . ; yarn lint:fix ; yarn format",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "glob": "^13.0.6",
    "tsx": "^4.23.0",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "tar": "^7.5.16",
    "lodash": "^4.18.0",
    "minimatch": "^10.2.3",
    "@isaacs/brace-expansion": "^5.0.1",
    "uuid": "^14.0.1",
    "ip-address": "^10.1.1",
    "picomatch": "^4.0.4",
    "diff": "^4.0.4"
  }
}
