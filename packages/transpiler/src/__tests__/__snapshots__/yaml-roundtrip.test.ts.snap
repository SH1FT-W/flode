"alias: Climate Control Based on Presence
description: Adjust temperature based on occupancy and time
triggers:
  - trigger: state
    entity_id: binary_sensor.occupancy
    for: "00:05:00"
actions:
  - choose:
      - conditions:
          - condition: and
            conditions:
              - condition: state
                entity_id: binary_sensor.occupancy
                state: "on"
              - condition: time
                after: "08:00:00"
                before: "22:00:00"
        sequence:
          - action: climate.set_temperature
            target:
              entity_id: climate.main
            data:
              temperature: 22
      - conditions:
          - condition: and
            conditions:
              - condition: state
                entity_id: binary_sensor.occupancy
                state: "on"
              - condition: time
                after: "22:00:00"
        sequence:
          - action: climate.set_temperature
            target:
              entity_id: climate.main
            data:
              temperature: 20
    default:
      - action: climate.set_temperature
        target:
          entity_id: climate.main
        data:
