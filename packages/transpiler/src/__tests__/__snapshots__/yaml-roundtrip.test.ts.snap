                target:
                  entity_id: switch.ensuite_fan
            else:
              - delay:
                  hours: 1
                  minutes: 0
                  seconds: 0
                  milliseconds: 0
              - metadata: {}
                action: switch.turn_off
                target:
                  entity_id: switch.ensuite_fan
mode: restart
