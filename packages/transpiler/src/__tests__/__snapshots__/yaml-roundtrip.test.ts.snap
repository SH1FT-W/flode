"alias: Plex Light Toggle - Living Room
description: |-
  Sets Movie Lights when Playing, Turns on Couch Light when Paused after sunset.
  Includes a 2-second delay for scrubbing and smooth dimming transitions.
triggers:
  - trigger: state
    entity_id:
      - media_player.v3plus
      - media_player.shield
    to: playing
    id: playing
  - trigger: state
    entity_id:
      - media_player.v3plus
      - media_player.shield
    to: paused
    for:
      seconds: 2
    id: paused
conditions:
  - condition: sun
    after: sunset
    after_offset: "00:05:00"
actions:
  - choose:
      - conditions:
          - condition: trigger
            id: playing
        sequence:
          - action: light.turn_off
            target:
              entity_id:
                - light.0a12b58eadb1ae45d36fdb96e025444d
                - light.751314eaa8749ab751d478948a65b33e
            data:
              transition: 2
      - conditions:
          - condition: trigger
            id: paused
        sequence:
          - action: light.turn_on
            target:
              entity_id: light.751314eaa8749ab751d478948a65b33e
            data:
              brightness_pct: 5
              transition: 3
mode: restart
variables:
  _flode_metadata:
    version: 1
    nodes:
      trigger_test_0_122:
        x: 40
        "y": 277
      trigger_test_1_123:
        x: 40
