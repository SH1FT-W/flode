exports[`YAML round-trip (fixtures) > round-trips 02-knx-complex.yaml to identical YAML 1`] = `
"alias: KNX Night/Morning Automation
description: Handle KNX button presses for night/morning scenes
triggers:
  - alias: KNX Button Press
    trigger: device
    domain: knx
    device_id: ee504a40b987814032d9ec9c29b1a43f
    type: telegram
    group_value_write: true
    group_value_response: true
    group_value_read: true
    incoming: true
    outgoing: false
    destination:
      - 2/0/11
      - 2/0/5
actions:
  - alias: Time-based Scene Selection
    if:
      - condition: or
        conditions:
          - condition: sun
            after: sunset
            after_offset: "-03:00:00"
          - condition: sun
            before: sunrise
            before_offset: "-03:00:00"
    then:
      - alias: Night Scene
        action: script.turn_on
        target:
          entity_id: script.buonanotte
    else:
      - alias: Morning Scene
        action: script.turn_on
        target:
          entity_id: script.buongiorno
mode: single
variables:
  _flode_metadata:
    version: 1
    nodes:
      trigger_test_0_186:
        x: 40
        "y": 57
      condition_test_1_187:
        x: 360
        "y": 47
      action_test_2_188:
        x: 700
        "y": 40
      action_test_3_189:
        x: 700
        "y": 180
    graph_id: a18b0fbb-d966-432c-aba7-4f7361da8d29
    graph_version: 1
    strategy: native
"
`;

exports[`YAML round-trip (fixtures) > round-trips 03-multiple-conditions.yaml to identical YAML 1`] = `
"alias: Movie Mode Automation
description: Close covers when movie starts with proper conditions
triggers:
  - trigger: state
    entity_id: media_player.tv
    to: playing
    for: "00:00:05"
conditions:
  - condition: numeric_state
    entity_id: sensor.brightness_sensor
    above: 120
  - condition: template
    value_template: "{% set app = (state_attr('media_player.tv', 'app_name') or '') | string %} {% set ok_apps = ['TV','Apple TV','Prime Video','Netflix'] %} {{ app in ok_apps }}"
  - condition: template
    value_template: "{{ (state_attr('media_player.tv','media_content_type') or '') | lower == 'movie' }}"
actions:
  - choose:
      - conditions:
          - condition: template
            value_template: "{{ states('cover.velux_blind') != 'closed' }}"
        sequence:
          - action: cover.close_cover
            target:
              entity_id: cover.velux_blind
      - conditions:
          - condition: template
            value_template: "{{ states('cover.main_blind') != 'closed' }}"
        sequence: []
  - action: cover.close_cover
    target:
      entity_id: cover.main_blind
mode: single
variables:
